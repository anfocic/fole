---
import SocialLinks from "./SocialLinks.astro";
import { heroSocialLinkIds } from "../data/social-links";
---

<section class="hero">
  <div class="portrait-wrap">
    <img
      class="portrait"
      src="/andrej.jpg"
      alt="Andrej Focic"
      width="280"
      height="280"
    />
  </div>
  <div class="copy">
    <h1>
      Hey, I'm <span class="accent">Andrej</span>
    </h1>
    <p class="role">Founder & engineer at <a href="https://intrebit.com" target="_blank" rel="noopener noreferrer">intrebit</a>.</p>
    <p class="role">Based in Dublin.</p>
    <SocialLinks ids={heroSocialLinkIds} variant="hero" />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(180px, 240px) 1fr;
    align-items: center;
    gap: 8rem;
    padding: 3.5rem 0;
  }

  .portrait-wrap {
    display: flex;
    justify-content: center;
  }

  .portrait {
    width: min(100%, 240px);
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--border) 82%, var(--accent));
    background: var(--bg-secondary);
  }

  .copy {
    min-width: 0;
  }

  h1 {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  .accent {
    color: var(--accent);
  }

  .role {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 0;
  }

  .role:last-of-type {
    margin-bottom: 1.5rem;
  }

  @media (max-width: 640px) {
    .hero {
      grid-template-columns: 100px 1fr;
      gap: 1.25rem;
      padding: 2.5rem 0;
    }

    h1 {
      font-size: 1.75rem;
      margin-bottom: 0.25rem;
    }

    .portrait {
      width: 100px;
    }

    .role {
      font-size: 0.95rem;
    }
  }
</style>
