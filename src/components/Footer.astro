---
import SocialLinks from "./SocialLinks.astro";
import { footerSocialLinkIds } from "../data/social-links";

const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <SocialLinks ids={footerSocialLinkIds} variant="footer" />
    <p class="copyright">&copy; {year} Andrej Focic. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: auto;
  }

  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .copyright {
    color: var(--text-secondary);
    font-size: 0.8rem;
    margin: 0;
  }
</style>
