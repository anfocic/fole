---
import ThemeToggle from "./ThemeToggle.astro";
---

<header>
  <nav class="container">
    <a href="/" class="logo">fole.dev</a>
    <div class="nav-right">
      <a href="/blog/">Blog</a>
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--accent);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-right a {
    color: var(--text-secondary);
    font-size: 0.95rem;
    position: relative;
    text-decoration: none;
  }

  .nav-right a::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.25s ease;
  }

  .nav-right a:hover {
    color: var(--accent);
  }

  .nav-right a:hover::after {
    width: 100%;
  }
</style>
