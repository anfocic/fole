---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Andrej Focic">
  <section class="not-found">
    <h1>404</h1>
    <p>This page doesn't exist. Maybe it never did.</p>
    <a href="/">Go home</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 6rem 0;
  }

  h1 {
    font-size: 5rem;
    margin-bottom: 0.5rem;
    color: var(--accent);
  }

  p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  a {
    font-size: 1rem;
  }
</style>
