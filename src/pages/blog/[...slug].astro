---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostAnalytics from "../../components/PostAnalytics.astro";
import { getBlogPosts, getPostReadingTime, getPostSlug } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = getBlogPosts(await getCollection("blog"), {
    includeDrafts: import.meta.env.DEV,
  });
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatted = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const readingTime = getPostReadingTime(post);
const isDraftPreview = import.meta.env.DEV && post.data.draft;
---

<BaseLayout
  title={`${post.data.title} — Andrej Focic`}
  description={post.data.description}
  image={post.data.coverImage}
  canonical={post.data.canonicalURL}
  type="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    {post.data.updatedDate && (
      <meta property="article:modified_time" content={post.data.updatedDate.toISOString()} />
    )}
    <meta name="author" content={post.data.author} />
    {post.data.tags.map((tag) => <meta property="article:tag" content={tag} />)}
  </Fragment>
  <article class="post">
    <a href="/blog/" class="back">&larr; Back to blog</a>
    {isDraftPreview && (
      <p class="draft-notice">Draft preview. This page is only available locally during development.</p>
    )}
    <header>
      <h1>{post.data.title}</h1>
      <div class="meta">
        <time datetime={post.data.date.toISOString()}>{formatted}</time>
        <span class="sep">&middot;</span>
        <span>{readingTime} min read</span>
      </div>
    </header>
    <div class="content" data-post-content>
      <Content />
    </div>
  </article>
  {!post.data.draft && <PostAnalytics slug={getPostSlug(post)} readingTime={readingTime} />}
</BaseLayout>

<style>
  .draft-notice {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.35rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--border));
    border-radius: 999px;
    color: var(--accent);
    font-size: 0.85rem;
  }

  .back {
    display: inline-block;
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .back:hover {
    color: var(--accent);
  }

  h1 {
    margin-bottom: 0.5rem;
  }

  .meta {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 2.5rem;
  }

  .sep {
    margin: 0 0.4rem;
  }

  .content {
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
  }

  .content :global(a) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
